{
  "name": "@petersr/claude-pty-web-harness-server",
  "version": "0.1.0",
  "description": "Reference Fastify + WebSocket adapter that exposes a ClaudeHarness over HTTP/WS.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "claude-pty-web-harness-server": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterSR/claude-pty-web-harness.git",
    "directory": "packages/server"
  },
  "bugs": "https://github.com/PeterSR/claude-pty-web-harness/issues",
  "homepage": "https://github.com/PeterSR/claude-pty-web-harness#readme",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@petersr/claude-pty-web-harness-core": "^0.1.0",
    "@petersr/claude-pty-web-harness-protocol": "^0.1.0",
    "@fastify/websocket": "^11.0.1",
    "fastify": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
