{
  "name": "@claude-pty-harness/server",
  "version": "0.0.1",
  "description": "Reference Fastify + WebSocket adapter that exposes a ClaudeHarness over HTTP/WS.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "claude-pty-harness-server": "src/server.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@claude-pty-harness/core": "*",
    "@claude-pty-harness/protocol": "*",
    "@fastify/websocket": "^11.0.1",
    "fastify": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
