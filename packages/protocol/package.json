{
  "name": "@petersr/claude-pty-web-harness-protocol",
  "version": "0.1.0",
  "description": "Shared wire types for the claude-pty-web-harness (zero runtime).",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterSR/claude-pty-web-harness.git",
    "directory": "packages/protocol"
  },
  "bugs": "https://github.com/PeterSR/claude-pty-web-harness/issues",
  "homepage": "https://github.com/PeterSR/claude-pty-web-harness#readme",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
