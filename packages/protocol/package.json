{
  "name": "@petersr/claude-pty-web-harness-protocol",
  "version": "0.3.0",
  "description": "Shared wire types for the claude-pty-web-harness (zero runtime).",
  "keywords": [
    "claude",
    "claude-code",
    "pty",
    "harness",
    "protocol",
    "types",
    "websocket"
  ],
  "author": "Peter Severin Rasmussen <git@petersr.com>",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterSR/claude-pty-web-harness.git",
    "directory": "packages/protocol"
  },
  "bugs": "https://github.com/PeterSR/claude-pty-web-harness/issues",
  "homepage": "https://github.com/PeterSR/claude-pty-web-harness#readme",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
