{
  "name": "@petersr/claude-pty-web-harness-core",
  "version": "0.3.0",
  "description": "Transport-agnostic core: drive Claude Code in a pupptyeer pty, stream its JSONL as chat events.",
  "keywords": [
    "claude",
    "claude-code",
    "pty",
    "pupptyeer",
    "harness",
    "jsonl",
    "terminal",
    "agent"
  ],
  "author": "Peter Severin Rasmussen <git@petersr.com>",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterSR/claude-pty-web-harness.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/PeterSR/claude-pty-web-harness/issues",
  "homepage": "https://github.com/PeterSR/claude-pty-web-harness#readme",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "tsx --test src/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@petersr/claude-pty-web-harness-protocol": "^0.3.0",
    "pupptyeer-client": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
