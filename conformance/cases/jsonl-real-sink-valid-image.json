              { "type": "image", "source": { "type": "base64", "media_type": "image/png", "data": "aGVsbG8gd29ybGQ=" } }
            ]
          }
        ]
      }
    },
    "lineNo": 1
  },
  "expect": [
    {
      "id": "u1:tr:0",
      "ts": "t1",
